# Kiwoom REST API
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
KIWOOM_ENV=mock

# LS Securities OPEN API
LS_APP_KEY=
LS_APP_SECRET_KEY=
# Optional for environments/accounts that require the LS mac_address header.
LS_MAC_ADDRESS=
LS_ENV=prod

# DB Securities OPEN API
DB_APP_KEY=
DB_APP_SECRET_KEY=
# Optional for environments/accounts that require the DB mac_address header.
DB_MAC_ADDRESS=
DB_ENV=prod

# Korea Investment & Securities Open API
KIS_APP_KEY=
KIS_APP_SECRET_KEY=
KIS_ENV=prod
KIS_CUSTOMER_TYPE=P
# Optional for KIS account read-only examples/caller params.
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01

# Live verification guards
# Keep disabled unless you are intentionally running local live-readonly examples.
SECURITY_API_LIVE_READONLY=false

# Live order submission must stay disabled unless a separate approved order goal enables it.
SECURITY_API_ALLOW_LIVE_ORDER=false
